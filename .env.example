# Application
NODE_ENV=development
PORT=3000

# Laravel Integration
LARAVEL_URL=http://localhost:8000
LARAVEL_API_KEY=your_api_key_here
API_SHARED_SECRET=your_shared_secret_here

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=exbotix_wallet
DB_USER=wallet_service
DB_PASSWORD=dev_password_change_in_production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Security - CRITICAL: Change these in production!
MASTER_ENCRYPTION_KEY=change-this-to-secure-random-string-in-production

# Blockchain RPC URLs (will configure later)
# BITCOIN_RPC_URL=
# ETHEREUM_RPC_URL=
# TRON_API_URL=
# SOLANA_RPC_URL=
