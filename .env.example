# Application
NODE_ENV=development
PORT=3000

# Laravel Integration (for API authentication)
LARAVEL_URL=http://localhost:8000
LARAVEL_API_SECRET=your_shared_secret_for_hmac_authentication

# Redis (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379

