# Application
NODE_ENV=development
PORT=3000

# Laravel Integration
LARAVEL_URL=http://localhost:8000
LARAVEL_API_KEY=your_api_key_here
API_SHARED_SECRET=your_shared_secret_here

# Database (will configure later)
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=wallet_service
# DB_USER=wallet_user
# DB_PASSWORD=your_password_here

# Redis (will configure later)
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=your_password_here

# Encryption (will configure later)
# MASTER_ENCRYPTION_KEY=your_master_key_min_32_chars_long

# Blockchain RPC URLs (will configure later)
# BITCOIN_RPC_URL=
# ETHEREUM_RPC_URL=
# TRON_API_URL=
# SOLANA_RPC_URL=
